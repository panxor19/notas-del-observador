---
import { siteConfig } from '@/config/site';

const giscus = siteConfig.giscus;
const enabled = Boolean(giscus.repo && giscus.repoId && giscus.category && giscus.categoryId);
---

{enabled && (
  <section class="mt-12 border-t border-[var(--line)] pt-8">
    <h2 class="text-2xl font-semibold">Comentarios</h2>
    <div class="mt-5">
      <script
        is:inline
        src="https://giscus.app/client.js"
        data-repo={giscus.repo}
        data-repo-id={giscus.repoId}
        data-category={giscus.category}
        data-category-id={giscus.categoryId}
        data-mapping={giscus.mapping}
        data-strict="0"
        data-reactions-enabled="1"
        data-emit-metadata="0"
        data-input-position="bottom"
        data-theme="preferred_color_scheme"
        data-lang="es"
        crossorigin="anonymous"
        async
      ></script>
    </div>
  </section>
)}

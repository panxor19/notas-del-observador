---
import TagBadge from './TagBadge.astro';
import { formatDate } from '@/utils/formatDate';
import { getPostSlug, getReadingTime, type BlogPost } from '@/utils/posts';

interface Props {
  post: BlogPost;
  featured?: boolean;
}

const { post, featured = false } = Astro.props;
const slug = getPostSlug(post);
const readingTime = getReadingTime(post);
---

<article class={`rounded-lg border border-[var(--line)] bg-[var(--panel)] p-5 shadow-sm transition hover:-translate-y-0.5 hover:shadow-soft ${featured ? 'md:p-6' : ''}`}>
  <div class="flex flex-wrap items-center gap-2 text-xs text-[var(--muted)]">
    <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
    <span aria-hidden="true">·</span>
    <span>{readingTime.text}</span>
    {post.data.category && <span class="rounded-md bg-signal/10 px-2 py-1 text-signal dark:text-teal-200">{post.data.category}</span>}
  </div>
  <h2 class={`mt-3 font-semibold leading-tight ${featured ? 'text-2xl' : 'text-xl'}`}>
    <a class="hover:text-signal dark:hover:text-teal-300" href={`/blog/${slug}`}>{post.data.title}</a>
  </h2>
  <p class="mt-3 text-sm leading-6 text-[var(--muted)]">{post.data.description}</p>
  <div class="mt-4 flex flex-wrap gap-2">
    {post.data.tags.map((tag) => <TagBadge tag={tag} />)}
  </div>
</article>

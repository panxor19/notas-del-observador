---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard from '@/components/PostCard.astro';
import { getAllTags, getPublishedPosts } from '@/utils/posts';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  return getAllTags(posts).map((tag) => ({
    params: { tag },
    props: { tag, posts: posts.filter((post) => post.data.tags.includes(tag)) }
  }));
}

const { tag, posts } = Astro.props;
---

<BaseLayout title={`Tag: ${tag}`} description={`Artículos publicados con el tag ${tag}.`}>
  <section class="mx-auto max-w-5xl px-4 py-12 sm:px-6">
    <a class="text-sm text-[var(--muted)] hover:text-[var(--fg)]" href="/tags">← Todos los tags</a>
    <h1 class="mt-4 text-4xl font-semibold">#{tag}</h1>
    <p class="mt-3 text-[var(--muted)]">{posts.length} artículo{posts.length === 1 ? '' : 's'} publicado{posts.length === 1 ? '' : 's'}.</p>
    <div class="mt-8 grid gap-4">
      {posts.map((post) => <PostCard post={post} />)}
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard from '@/components/PostCard.astro';
import { getPublishedPosts } from '@/utils/posts';

const posts = await getPublishedPosts();
---

<BaseLayout title="Blog" description="Todos los artículos publicados en Notas del Observador.">
  <section class="mx-auto max-w-5xl px-4 py-12 sm:px-6">
    <header class="mb-8">
      <h1 class="text-4xl font-semibold">Artículos</h1>
      <p class="mt-3 max-w-2xl text-[var(--muted)]">Reflexiones, tecnología, inteligencia artificial, desarrollo de software y observaciones del mundo moderno.</p>
    </header>
    <div class="grid gap-4">
      {posts.map((post) => <PostCard post={post} />)}
    </div>
  </section>
</BaseLayout>

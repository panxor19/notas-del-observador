---
import PostLayout from '@/layouts/PostLayout.astro';
import { render } from 'astro:content';
import { getPostSlug, getPublishedPosts, getRelatedPosts, type BlogPost } from '@/utils/posts';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();

  return posts.map((post, index) => ({
    params: { slug: getPostSlug(post) },
    props: {
      post,
      posts,
      previous: posts[index + 1],
      next: posts[index - 1]
    }
  }));
}

interface Props {
  post: BlogPost;
  posts: BlogPost[];
  previous?: BlogPost;
  next?: BlogPost;
}

const { post, posts, previous, next } = Astro.props;
const { Content, headings } = await render(post);
const relatedPosts = getRelatedPosts(post, posts);
---

<PostLayout post={post} headings={headings} relatedPosts={relatedPosts} previous={previous} next={next}>
  <Content />
</PostLayout>

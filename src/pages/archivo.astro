---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TagBadge from '@/components/TagBadge.astro';
import { formatDate } from '@/utils/formatDate';
import { getPostSlug, getPublishedPosts } from '@/utils/posts';

const posts = await getPublishedPosts();
const archive = posts.reduce<Record<string, typeof posts>>((groups, post) => {
  const key = new Intl.DateTimeFormat('es-CL', { month: 'long', year: 'numeric', timeZone: 'UTC' }).format(post.data.pubDate);
  groups[key] = groups[key] ?? [];
  groups[key].push(post);
  return groups;
}, {});
---

<BaseLayout title="Archivo" description="Archivo cronológico de artículos publicados.">
  <section class="mx-auto max-w-5xl px-4 py-12 sm:px-6">
    <h1 class="text-4xl font-semibold">Archivo</h1>
    <p class="mt-3 text-[var(--muted)]">Posts agrupados por mes y año.</p>
    <div class="mt-9 space-y-9">
      {Object.entries(archive).map(([period, periodPosts]) => (
        <section>
          <h2 class="border-b border-[var(--line)] pb-2 text-2xl font-semibold capitalize">{period}</h2>
          <div class="mt-4 space-y-4">
            {periodPosts.map((post) => (
              <article class="grid gap-3 rounded-lg border border-[var(--line)] bg-[var(--panel)] p-4 md:grid-cols-[10rem_minmax(0,1fr)]">
                <time class="text-sm text-[var(--muted)]" datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
                <div>
                  <h3 class="font-semibold"><a class="hover:text-signal dark:hover:text-teal-300" href={`/blog/${getPostSlug(post)}`}>{post.data.title}</a></h3>
                  <p class="mt-1 text-sm text-[var(--muted)]">{post.data.description}</p>
                  <div class="mt-3 flex flex-wrap gap-2">
                    {post.data.tags.map((tag) => <TagBadge tag={tag} />)}
                  </div>
                </div>
              </article>
            ))}
          </div>
        </section>
      ))}
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from './BaseLayout.astro';
import TagBadge from '@/components/TagBadge.astro';
import TableOfContents from '@/components/TableOfContents.astro';
import ShareButtons from '@/components/ShareButtons.astro';
import RelatedPosts from '@/components/RelatedPosts.astro';
import PostNavigation from '@/components/PostNavigation.astro';
import CommentSection from '@/components/CommentSection.astro';
import { formatDate } from '@/utils/formatDate';
import { getPostSlug, getReadingTime, type BlogPost } from '@/utils/posts';

interface Props {
  post: BlogPost;
  headings: { depth: number; slug: string; text: string }[];
  relatedPosts: BlogPost[];
  previous?: BlogPost;
  next?: BlogPost;
}

const { post, headings, relatedPosts, previous, next } = Astro.props;
const readingTime = getReadingTime(post);
const slug = getPostSlug(post);
---

<BaseLayout title={post.data.title} description={post.data.description} image={post.data.cover} type="article">
  <article class="mx-auto max-w-6xl px-4 py-10 sm:px-6 lg:py-14">
    <header class="mx-auto max-w-3xl">
      <div class="flex flex-wrap items-center gap-2 text-sm text-[var(--muted)]">
        <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
        <span aria-hidden="true">·</span>
        <span>{readingTime.text}</span>
        <span aria-hidden="true">·</span>
        <span>{post.data.author}</span>
      </div>
      <h1 class="mt-5 text-4xl font-semibold leading-tight sm:text-5xl">{post.data.title}</h1>
      <p class="mt-5 text-lg leading-8 text-[var(--muted)]">{post.data.description}</p>
      {post.data.updatedDate && (
        <p class="mt-3 text-sm text-[var(--muted)]">Actualizado el {formatDate(post.data.updatedDate)}</p>
      )}
      <div class="mt-6 flex flex-wrap gap-2">
        {post.data.tags.map((tag) => <TagBadge tag={tag} />)}
      </div>
    </header>

    {post.data.cover && (
      <img class="mx-auto mt-10 aspect-[16/9] w-full max-w-5xl rounded-lg object-cover" src={post.data.cover} alt="" loading="eager" />
    )}

    <div class="mt-10 grid gap-8 lg:grid-cols-[minmax(0,1fr)_16rem]">
      <div class="min-w-0">
        <div class="prose-observer mx-auto max-w-3xl" data-pagefind-body>
          <slot />
        </div>
        <div class="mx-auto mt-10 max-w-3xl">
          <ShareButtons title={post.data.title} path={`/blog/${slug}`} />
        </div>
      </div>
      <div class="hidden lg:block">
        <div class="sticky top-24">
          <TableOfContents headings={headings} />
        </div>
      </div>
    </div>

    <div class="mx-auto max-w-5xl">
      <RelatedPosts posts={relatedPosts} />
      <PostNavigation previous={previous} next={next} />
      <CommentSection />
    </div>
  </article>
</BaseLayout>
